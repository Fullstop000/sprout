ARK_API_KEY=your-api-key
ARK_BASE_URL=https://ark-cn-beijing.bytedance.net/api/v3
ARK_MODEL=ep-20260304142209-cd44k

# Runtime mode: autonomous (default) or legacy
RUN_MODE=autonomous

# Common runtime tuning
POLL_INTERVAL_SECONDS=60
COMMAND_TIMEOUT_SECONDS=60
WEB_RESULT_LIMIT=5
LOG_RETENTION_DAYS=30
DAEMON_RESTART_DELAY_SECONDS=5
DAEMON_MAX_RESTARTS=0

# Autonomous mode tuning
AUTONOMOUS_MAX_ACTIONS=5
# AUTONOMOUS_STATE_PATH=/absolute/path/to/workspace/.llm247/autonomous_state.json

# Optional workspace overrides
# WORKSPACE_PATH=/absolute/path/to/workspace
# STATE_PATH=/absolute/path/to/workspace/.llm247/state.json
# REPORT_DIR=/absolute/path/to/workspace/reports/llm247
# LOG_PATH=/absolute/path/to/workspace/.llm247/worker.log
